# ── Secrets ───────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS
VITE_ENCRYPTION_KEY=REPLACE_WITH_SAME_64_HEX_CHARS

JWT_SECRET=REPLACE_WITH_STRONG_SECRET
ADMIN_JWT_SECRET=REPLACE_WITH_STRONG_SECRET

# Database
DB_USER=postgres
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DB_NAME=sahayak

# Seed admin account — change immediately after first login
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# CORS — comma-separated list of allowed origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:8080

# ── AWS Bedrock (LLM) ─────────────────────────────────────────────────────────
AWS_BEARER_TOKEN_BEDROCK=REPLACE_WITH_YOUR_BEDROCK_API_KEY
AWS_REGION=eu-north-1
BEDROCK_MODEL_ID=openai.gpt-oss-20b-1:0
